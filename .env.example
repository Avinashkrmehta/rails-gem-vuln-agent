# LLM Provider (openai, anthropic, or gen_ai)
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Anthropic (alternative)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Internal Gen AI Gateway (same as lx-edcast settings.yml gen_ai section)
# Uses JWT auth with RS256, backed by AWS Bedrock (Amazon Nova / Claude)
# Set provider to 'gen_ai' in config.yaml, OR just set these vars and
# the agent will auto-detect if no OpenAI/Anthropic key is present.
GEN_AI_API_PRIVATE_KEY=
GEN_AI_API_PUBLIC_KEY_URL=
GEN_AI_API_PUBLIC_KEY_ID=
GEN_AI_API_HOST=
GEN_AI_AUD_URL=
GEN_AI_MAX_TOKENS=2000
GEN_AI_API_TIME_OUT=30
# Bedrock-specific (optional, if separate endpoint)
GEN_AI_BEDROCK_API_HOST=
GEN_AI_BEDROCK_AUD_URL=

# GitHub (for PR creation - if using GitHub)
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# Bitbucket Server (self-hosted, e.g., bitbucket.csod.com)
# GIT_PLATFORM=bitbucket
BITBUCKET_SERVER_URL=
BITBUCKET_TOKEN=
BITBUCKET_PROJECT=
BITBUCKET_REPO_SLUG=

# Jira ticket prefix (required if Bitbucket has YACC commit hook)
# The commit message will be: "LX-0000: fix(security): Upgrade gem..."
JIRA_TICKET_PREFIX=

# Bitbucket Cloud (bitbucket.org) — only if NOT using Server
# BITBUCKET_USERNAME=
# BITBUCKET_APP_PASSWORD=
# BITBUCKET_WORKSPACE=
# BITBUCKET_REPO_SLUG=

# Rails App Path (default, can be overridden via CLI)
RAILS_APP_PATH=/path/to/your/rails/app

# Agent Settings
MAX_RETRIES=3
LOG_LEVEL=INFO

